{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RAGE",
  "version": "1.0.0",
  "identifier": "com.rage.messenger",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:3001",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RAGE Messenger",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
